# case-chat cloud deploy — copy to deploy/.env and fill in.

# --- Chat model (vLLM / DiffusionGemma) ------------------------------------
# DiffusionGemma is a block-diffusion LLM (26B MoE, ~3.8B active). On the 5090
# (Blackwell) use the NVFP4 4-bit quant — it fits ~18GB and FP4 is hardware-
# accelerated. NVFP4 requires a Blackwell GPU; on Ada/Ampere you need a
# different int4 quant or the bf16 repo (google/diffusiongemma-26B-A4B-it).
VLLM_MODEL=RedHatAI/diffusiongemma-26B-A4B-it-NVFP4
# Context window. The recipe's 262144 targets a B200; 32768 fits the 5090 KV.
VLLM_MAX_MODEL_LEN=32768
# Diffusion state buffers pre-allocate max_seqs × canvas × vocab — keep ≤4 or it OOMs.
VLLM_MAX_NUM_SEQS=4
# Fraction of GPU memory vLLM may use. The recipe wants 0.85 (activation headroom
# during denoising) ASSUMING vLLM owns the card. TEI shares this 5090, so either
# run TEI on CPU (see deploy/docker-compose.5090.yml) and keep 0.85, or drop this
# to ~0.6 to leave ~8GB for a GPU TEI (tighter, less diffusion headroom).
VLLM_GPU_FRACTION=0.85

# --- Embeddings (TEI / Qwen3-Embedding-4B) ---------------------------------
EMBEDDINGS_MODEL=Qwen/Qwen3-Embedding-4B

# --- Hugging Face (model downloads; required if any model is gated) --------
HF_TOKEN=

# --- Cloudflare Tunnel -----------------------------------------------------
# Create a tunnel in the Cloudflare dashboard, route a public hostname to
# http://web:8080, and paste the connector token here.
TUNNEL_TOKEN=

# --- Host paths mounted into the containers --------------------------------
# The knowledgedb pg_dump (build profile only) and the synthetic corpus.
DUMP_PATH=/opt/case-chat/knowledgedb.dump
SYNTHETIC_CORPUS_PATH=/opt/case-chat/synthetic-test-corpus

# --- Web app + auth (read by the app via CASECHAT_*) -----------------------
# REQUIRED: a long random secret.  openssl rand -hex 32
CASECHAT_WEB_AUTH_SECRET=
# The public HTTPS hostname Cloudflare serves (used to mint magic links).
CASECHAT_WEB_PUBLIC_BASE_URL=https://your-tunnel-hostname.example
CASECHAT_ACTIVE_JURISDICTION=ar
