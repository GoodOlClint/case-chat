# case-chat — environment overrides for the 5090 box deployment.
# Copy to .env on the box and adjust. Local dev needs NONE of these (defaults
# target Ollama + localhost). Everything here is read by case_chat/config.py.

# --- Chat model: real vLLM serving DiffusionGemma --------------------------
CASECHAT_VLLM_BASE_URL=http://localhost:8000/v1
CASECHAT_VLLM_MODEL=google/diffusiongemma-26B-A4B-it
# 5090/4-bit: set to the quant repo id you actually serve, and a context that
# fits the 32GB KV cache (the recipe's 262144 targets a B200).
CASECHAT_VLLM_CONTEXT_WINDOW=32768
CASECHAT_VLLM_SEND_CHAT_TEMPLATE_KWARGS=true
CASECHAT_VLLM_ENABLE_THINKING=true

# --- Embeddings: TEI serving Qwen3-Embedding-4B (same 2560 contract) --------
CASECHAT_EMBEDDINGS_BASE_URL=http://localhost:8001/v1
CASECHAT_EMBEDDINGS_MODEL=Qwen/Qwen3-Embedding-4B

# --- Qdrant ----------------------------------------------------------------
CASECHAT_QDRANT_URL=http://localhost:6333

# --- Web app + auth (externally reachable behind Cloudflare Tunnel) ---------
CASECHAT_WEB_HOST=127.0.0.1
CASECHAT_WEB_PORT=8080
# REQUIRED in prod — a long random secret. Generate: openssl rand -hex 32
CASECHAT_WEB_AUTH_SECRET=change-me-to-a-long-random-secret
CASECHAT_WEB_PUBLIC_BASE_URL=https://your-tunnel-hostname.example
CASECHAT_WEB_COOKIE_SECURE=true
